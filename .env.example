# Backend
POSTGRES_USER=mathloop
POSTGRES_PASSWORD=change_this_postgres_password
POSTGRES_DB=mathloop
DATABASE_URL=postgresql+psycopg://mathloop:change_this_postgres_password@postgres:5432/mathloop
ENVIRONMENT=development
JWT_SECRET_KEY=change_me_to_a_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
CORS_ORIGINS=http://localhost:3000,https://your-domain.com

STORAGE_MODE=local
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=10

S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_PUBLIC_BASE_URL=
S3_REGION=auto

AI_MODE=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=

# Frontend
# 本地 Docker 可用 http://localhost:8000；云服务器请改成 http(s)://你的服务器或后端域名
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
