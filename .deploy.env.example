# Copy this file to .deploy.env and fill real temporary deployment credentials.
# Do not commit .deploy.env.

# GitHub
GITHUB_REPO=cyyshtyl-collab/mathloop

# Domains. Replace these with your real domains.
FRONTEND_DOMAIN=mathloop.your-domain.com
BACKEND_DOMAIN=api.mathloop.your-domain.com
IMAGE_DOMAIN=img.mathloop.your-domain.com

# Vercel
# Create at: Vercel -> Account Settings -> Tokens
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_NAME=mathloop

# Render
# Create at: Render -> Account Settings -> API Keys
RENDER_API_KEY=
RENDER_OWNER_ID=

# Cloudflare
# Create at: Cloudflare -> My Profile -> API Tokens
# Required permissions: Account R2 Storage Edit, Zone DNS Edit for your domain.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=

# R2 / app values
R2_BUCKET=mathloop-junior
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto

# App secret
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=
